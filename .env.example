# LLM — aligned with tender_knowledge (.env)
# Presets: qwen (default) | openai

LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=qwen3.7-max
LLM_ENABLE_THINKING=false
LLM_STREAM=true
LLM_LOG_STREAM=true
LLM_TIMEOUT=300

# interpret v2 OCR / segmentation
OCR_ENABLED=true
OCR_MODEL=qwen-vl-ocr
SEGMENT_MIN_TOKENS=2000
SEGMENT_MAX_TOKENS=12000

# Legacy aliases (still supported)
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# DOC_CHUNK_LLM_MODEL=

# Template extraction
TEMPLATE_WHOLE_DOC_MAX_CHARS=80000
TEMPLATE_SHARD_MAX_CHARS=24000
TEMPLATE_CHAR_CHUNK_OVERLAP=500
TEMPLATE_PLAN_ENABLED=true
