# LLM — aligned with tender_knowledge (.env)
# Presets: qwen (default) | openai

LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=qwen3.6-plus

# interpret v2 OCR / segmentation
OCR_ENABLED=true
OCR_MODEL=qwen-vl-ocr
SEGMENT_MIN_TOKENS=2000
SEGMENT_MAX_TOKENS=12000

# Legacy aliases (still supported)
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# DOC_CHUNK_LLM_MODEL=
